{
  "name": "@obey/monorepo",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "Bogdan Kolesnyk",
  "type": "module",
  "scripts": {
    "bootstrap": "run-p bootstrap:*",
    "bootstrap:husky": "husky",
    "bootstrap:workspaces": "turbo bootstrap",
    "build": "turbo build",
    "build:dev": "turbo build:dev",
    "check": "turbo check:types check:lint check:format",
    "deps:check": "turbo deps:check",
    "deps:update": "turbo deps:update",
    "dev": "turbo dev",
    "fix": "turbo fix:lint fix:format",
    "husky:commit-msg": "",
    "husky:pre-commit": "",
    "husky:pre-push": "",
    "prepare": "pnpm bootstrap",
    "release": "turbo release",
    "root:check:format": "prettier --check .",
    "root:check:lint": "eslint .",
    "root:check:package-json": "sort-package-json --check",
    "root:check:types": "tsc --noEmit",
    "root:check:knip": "tsc --noEmit",
    "root:deps:check": "ncu -e 1",
    "root:deps:test": "",
    "root:deps:update": "ncu -du --doctorTest \"pnpm root:deps:test\"",
    "root:fix:format": "prettier --write .",
    "root:fix:lint": "eslint --fix .",
    "root:fix:package-json": "sort-package-json",
    "test": "turbo test"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "knip": "6.3.0",
    "npm-check-updates": "20.0.0",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.1",
    "sort-package-json": "3.6.1",
    "turbo": "^2.9.4",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.33.0"
}
